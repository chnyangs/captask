# CapTask Configuration
# Copy to .env and adjust values as needed

# ── Server ──
PORT=3456
CAPTASK_HOST=0.0.0.0

# ── Data ──
# Directory for persistent files (sessions, messages, auth, projects)
# Default: project root
# CAPTASK_DATA_DIR=./data

# ── Logging ──
# "text" (human-readable) or "json" (structured, for log aggregation)
CAPTASK_LOG_FORMAT=text

# ── Limits ──
CAPTASK_MAX_PROMPT=100000
CAPTASK_MAX_BUFFER=10485760
CAPTASK_TASK_TIMEOUT_MS=1800000
CAPTASK_MAX_STREAM_CHUNK=1048576
CAPTASK_MAX_OUTPUT_BUFFER=200
CAPTASK_MAX_MESSAGES=200

# ── Rate Limiting ──
CAPTASK_RATE_WINDOW_MS=10000
CAPTASK_RATE_MAX_TASKS=5

# ── Session TTL ──
# How long sessions persist before auto-purge (ms)
CAPTASK_SESSION_TTL_MS=2592000000
# How long login tokens stay valid (ms)
CAPTASK_TOKEN_TTL_MS=86400000

